OPENAI_API_KEY=
DATABASE_URL=sqlite+aiosqlite:///./app.db
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=ai_outfit_store
MONGODB_PRODUCTS_COLLECTION=products
MONGODB_USERS_COLLECTION=users
MONGODB_ORDERS_COLLECTION=orders
SEED_PRODUCTS_COUNT=1000
AUTH_SECRET_KEY=dev-auth-secret-change-me
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_PRODUCTS_COLLECTION=products_embeddings
CHROMA_POLICY_COLLECTION=policy_embeddings
POLICY_DOCS_PATH=./docs/policies
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
TOP_K=5
REQUEST_TIMEOUT_SECONDS=8
USE_FAKE_EMBEDDINGS=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-product-search
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_TRACING=false
