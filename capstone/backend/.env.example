APP_NAME=incident-kb-assistant
APP_ENV=local
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_FILE_NAME=application.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5
API_PREFIX=/api/v1

MONGODB_URI=mongodb://mongodb:27017
MONGODB_DB=incident_kb
MONGODB_MAX_POOL_SIZE=50

CHROMA_PERSIST_DIR=/app/chroma
CHROMA_COLLECTION=incidents

OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=20
EMBEDDING_BATCH_SIZE=500

LANGSMITH_API_KEY=
LANGSMITH_PROJECT=incident-kb-assistant
LANGSMITH_PROJECT_URL=
LANGSMITH_TRACING=true

ADMIN_SESSION_SECRET=change_me_for_non_demo_use
ADMIN_SESSION_TTL_SECONDS=28800

RAW_DATASET_PATH=./data/raw/it_incidents_10k.csv
RESOLUTION_SEED_PATH=./data/raw/incident_resolution_seed.csv
PROCESSED_DATASET_PATH=/app/data/processed/incidents_cleaned.csv
