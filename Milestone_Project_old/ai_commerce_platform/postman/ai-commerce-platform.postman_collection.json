{
  "info": {
    "name": "AI Commerce Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "base_url", "value": "http://localhost:8000"},
    {"key": "token", "value": ""}
  ],
  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": "{{base_url}}/auth/register",
        "body": {"mode": "raw", "raw": "{\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"StrongPass123\",\n  \"role\": \"customer\"\n}"}
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": "{{base_url}}/auth/login",
        "body": {"mode": "raw", "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"StrongPass123\"\n}"}
      }
    },
    {
      "name": "List Products",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/products"
      }
    },
    {
      "name": "Search",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": "{{base_url}}/search",
        "body": {"mode": "raw", "raw": "{\n  \"query\": \"running shoes under 5000\",\n  \"filters\": {\"category\": \"shoes\"},\n  \"top_k\": 5\n}"}
      }
    }
  ]
}
