ENV=dev
LOG_LEVEL=INFO

MONGO_URI=mongodb://localhost:27017
MONGO_DB=ecommerce
MONGO_PRODUCTS_COLLECTION=products

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.2

LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=genai-ecommerce
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

XLSX_PATH=./data/walmart-products.xlsx
CHROMA_PATH=./chroma_data
CHROMA_COLLECTION=walmart_products
CHROMA_REVIEWS_COLLECTION=walmart_reviews

INGEST_BATCH_SIZE=64
MAX_REVIEWS_CHARS=3000
MAX_SPECS_CHARS=2000
MAX_OTHER_ATTRS_CHARS=2000
POOR_RATING_THRESHOLD=3.6
ALT_MIN_RATING=4.0
ALT_LIMIT=6
CHAT_MAX_REVIEWS_CHARS=3500
CHAT_MAX_SPECS_CHARS=2000
